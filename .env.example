# ========================================
# VARIÁVEIS DE AMBIENTE - EXEMPLO
# ========================================
# Copie este arquivo para .env e preencha com seus valores
# NUNCA faça commit do arquivo .env com dados sensíveis!

# ========================================
# BANCO DE DADOS
# ========================================
# Nome do DSN (Data Source Name) no ODBC
DB_DSN2=sua-dsn-aqui

# Usuário do banco de dados
DB_USER2=seu-usuario-aqui

# Senha do banco de dados
DB_PASS2=sua-senha-aqui

# ========================================
# CORS (Origens permitidas)
# ========================================
# Separadas por vírgula
# Exemplos:
# - Desenvolvimento: http://localhost:5173
# - Vercel: https://seu-projeto.vercel.app
# - Cloudflare: https://seu-projeto.pages.dev
CORS_ORIGINS=http://localhost:5173,https://seu-projeto.vercel.app

# ========================================
# FRONTEND (Vite)
# ========================================
# URL da API (usado no React)
# Preencha com a URL do seu backend em produção
VITE_API_URL=https://variables-etc-basketball-catalyst.trycloudflare.com

# ========================================
# CONFIGURAÇÕES DO SERVER
# ========================================
# Porta do Express
PORT=3000

# Ambiente (development, production)
NODE_ENV=development

